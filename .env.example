# .env.example — Copy to .env and fill in real values.
# NEVER commit .env to git — it contains secrets.
#
# Generate JWT_SECRET with: openssl rand -hex 64

JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
ASYNC_DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
DB_HOST=localhost
DB_PORT=5432
DB_USER=CHANGE_ME
DB_PASSWORD=CHANGE_ME
DB_NAME=hedgecalc
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=hedgecalc
ENV=dev

# ── Render REST API automation ────────────────────────────────────────────────
# Required by scripts/render/*.ps1
# Get API key: Render dashboard → Account Settings → API Keys → Create API Key
RENDER_API_KEY=rnd_CHANGE_ME

# Service IDs — discover by running: .\scripts\render\list-services.ps1
# hedgecore (production backend, master branch)
RENDER_API_SERVICE_ID=srv_CHANGE_ME
# hedgecore-preview (preview backend, dev branch)
RENDER_PREVIEW_SERVICE_ID=srv_CHANGE_ME

# Optional: Render owner ID (from your Render dashboard URL segment)
# RENDER_OWNER_ID=usr_CHANGE_ME

# Optional: "json" for machine-readable list-services output
# RENDER_OUTPUT=json

# ── Optional API keys ─────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
# FINNHUB_API_KEY=CHANGE_ME

# Optional: Redis for distributed rate limiting
# REDIS_URL=redis://localhost:6379/0

# Optional: HashiCorp Vault
# VAULT_ADDR=https://vault.yourcompany.com:8200
# VAULT_TOKEN=s.xxxxx

# Optional: AWS Secrets Manager
# AWS_SECRET_NAME=hedgecore/production
# AWS_REGION=us-east-1
