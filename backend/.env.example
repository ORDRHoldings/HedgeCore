# backend/.env.example — Copy to .env and fill in real values.
# NEVER commit .env to git — it contains secrets.

JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
ASYNC_DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
DB_HOST=localhost
DB_PORT=5432
DB_USER=CHANGE_ME
DB_PASSWORD=CHANGE_ME
DB_NAME=hedgecalc
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=hedgecalc
ENV=dev

# CORS — comma-separated frontend origins (NO wildcard when using httpOnly cookies)
# REQUIRED in production. Defaults to localhost:3000 + known Vercel URLs if unset.
# Example: CORS_ALLOW_ORIGINS=https://app.ordrterminal.com,https://ordr-terminal.vercel.app
# CORS_ALLOW_ORIGINS=

# Optional: Redis for distributed rate limiting
# REDIS_URL=redis://localhost:6379/0
