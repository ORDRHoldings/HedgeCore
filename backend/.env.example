# backend/.env.example — Copy to .env and fill in real values.
# NEVER commit .env to git — it contains secrets.

# ── Core ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
ENV=production  # dev | staging | production

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
ASYNC_DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
# Production releases should run migrations before the app starts. Set these
# true only for controlled single-instance bootstrap/development workflows.
RUN_ALEMBIC_ON_STARTUP=false
RUN_SCHEMA_BOOTSTRAP_ON_STARTUP=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated frontend origins. NO wildcard in production.
CORS_ALLOW_ORIGINS=https://app.ordrterminal.com,https://ordr-terminal.vercel.app
# Set true on staging/preview Render services to allow dynamic *.vercel.app origins:
# CORS_ALLOW_VERCEL_PREVIEWS=true

# ── Observability ─────────────────────────────────────────────────────────────
# Sentry error tracking — set to enable; omit to disable (no-op in dev/test).
# SENTRY_DSN=https://YOUR_KEY@o123456.ingest.sentry.io/PROJECT_ID

# ── Redis ─────────────────────────────────────────────────────────────────────
# Optional: Redis for distributed rate limiting + market data cache.
# REDIS_URL=redis://localhost:6379/0

# ── Market Data Providers ─────────────────────────────────────────────────────
# TwelveData: primary FX spot + equity quotes. Free tier: 800 calls/day, 8/min.
# TWELVEDATA_API_KEY=your_api_key_here
# TWELVEDATA_RATE_LIMIT=8
# TWELVEDATA_DAILY_LIMIT=800

# IBKR: Requires IB Gateway running locally — set false unless TWS is running.
# IBKR_ENABLED=false
# IBKR_HOST=127.0.0.1
# IBKR_PORT=4002
# IBKR_CLIENT_ID=1

# ── ERP Connector Framework ───────────────────────────────────────────────────
# Fernet 32-byte base64 key. Comma-separate multiple keys for rotation.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# REQUIRED in production when any ERP connector is enabled.
# CONNECTOR_ENCRYPTION_KEY=CHANGE_ME_fernet_key_here

# QuickBooks Online (OAuth 2.0)
# QBO_CLIENT_ID=
# QBO_CLIENT_SECRET=
# QBO_REDIRECT_URI=https://api.yourapp.com/v1/connectors/oauth/callback
# QBO_ENVIRONMENT=production  # sandbox | production

# Xero (OAuth 2.0)
# XERO_CLIENT_ID=
# XERO_CLIENT_SECRET=
# XERO_REDIRECT_URI=https://api.yourapp.com/v1/connectors/oauth/callback
# Note: XERO_CLIENT_SECRET also used as webhook HMAC key until XERO_WEBHOOK_KEY is added.

# NetSuite (OAuth 2.0)
# NETSUITE_CLIENT_ID=
# NETSUITE_CLIENT_SECRET=
# NETSUITE_REDIRECT_URI=https://api.yourapp.com/v1/connectors/oauth/callback

# Sage Intacct (XML Gateway / form auth)
# SAGE_INTACCT_SENDER_ID=
# SAGE_INTACCT_SENDER_PASSWORD=
# SAGE_INTACCT_REDIRECT_URI=

# Microsoft Dynamics 365 Finance (Azure AD)
# DYNAMICS365_CLIENT_ID=
# DYNAMICS365_CLIENT_SECRET=
# DYNAMICS365_TENANT_ID=  # Azure AD tenant UUID
# DYNAMICS365_REDIRECT_URI=https://api.yourapp.com/v1/connectors/oauth/callback

# ── HedgeWiki Integration ─────────────────────────────────────────────────────
# HEDGEWIKI_API_KEY=
# HEDGEWIKI_BASE_URL=https://hedgewiki.onrender.com
