# ORDR Terminal — Environment Variables
# Copy to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ── Backend ───────────────────────────────────────────────────────────────────
# Full URL of the deployed backend (no trailing slash).
NEXT_PUBLIC_API_URL=https://hedgecore.onrender.com

# ── Legacy API key clients ─────────────────────────────────────────────────────
# Used by src/api/{client,pipelineClient,policyClient,runsClient,positionClient}.ts
# and src/lib/api.ts (api-health page). Should be a per-tenant API key from the
# Access Control settings panel. Omit to leave header absent (auth falls back to JWT).
# WARNING: NEXT_PUBLIC_* vars are embedded in the JS bundle — use a read-only scoped key.
# NEXT_PUBLIC_HEDGECALC_API_KEY=HK_live_your_key_here
# NEXT_PUBLIC_API_KEY=HK_live_your_key_here

# ── Market Data ───────────────────────────────────────────────────────────────
# Finnhub API key (server-side only — do NOT add NEXT_PUBLIC_ prefix).
# FINNHUB_API_KEY=your_finnhub_api_key_here
